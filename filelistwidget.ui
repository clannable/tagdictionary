}

QPushButton, QToolButton {
	border-radius: 4px;
	border: 1px solid #b9b9b9;
	background-color: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 #f9f9f9, stop: 1 #e5e5e5);
	color: #3a3a3a; 
	height: 25px;
}

QPushButton:hover, QToolButton:hover {
	background-color: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 #c9c9c9, stop: 1 #a5a5a5);
    border-color: #8f8f8f;
}

QPushButton:pressed, QToolButton:pressed {
	background-color: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 #a9a9a9, stop: 1 #959595);
    border-color: #8f8f8f;
}

QPushButton:disabled, QToolButton:disabled {
	background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1, stop: 0 #dadada, stop: 1 #a5a5a5);
	border-color: #8e8e8e;
	color: #9a9a9a;
